# Chat 集成测试 LLM 配置, 如果配置了下面这些内容, 这个项目的测试就会调用真实API进行测试, 没有就会跳过

TEST_LLM_API_KEY=your-api-key-here
TEST_LLM_PROVIDER=minimax-cn
TEST_LLM_MODEL=MiniMax-M2.7

# 可用 Provider: openai, anthropic, google, xai, groq, openrouter, mistral, minimax, minimax-cn, zai, opencode, kimi-coding, huggingface, cerebras
